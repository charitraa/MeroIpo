# Nepal IPO Auto-Apply — runtime configuration.
# NOTE: this file is bundled as a Flutter asset. Do NOT put secrets here.
# MeroShare credentials are never stored here — they live in flutter_secure_storage.

# MeroShare API
MEROSHARE_BASE_URL=https://meroshare.cdsc.com.np/api/v2

# Optional backend (FCM relay only — never receives credentials). Leave blank to disable.
BACKEND_BASE_URL=

# Default IPO application quantity (shares)
DEFAULT_APPLY_QUANTITY=10

# Background poll interval in minutes
BACKGROUND_POLL_INTERVAL_MINUTES=120
